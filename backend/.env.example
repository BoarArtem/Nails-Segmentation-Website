# PostgreSQL connection string used by SQLAlchemy.
# Format: postgresql+psycopg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+psycopg://nails_user:nails_password@localhost:5432/nails_segmentation

# Secret key used to sign JWT access tokens. Generate a strong random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-secret

# JWT access token lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60
